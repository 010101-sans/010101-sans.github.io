<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/"><channel><title>Firebase on 010101-sans</title><link>https://010101-sans.github.io/tags/firebase/</link><description>Recent content in Firebase on 010101-sans</description><generator>Hugo -- 0.151.0</generator><language>en-us</language><lastBuildDate>Sat, 20 Jan 2024 10:00:00 +0000</lastBuildDate><atom:link href="https://010101-sans.github.io/tags/firebase/index.xml" rel="self" type="application/rss+xml"/><item><title>E-Commerce Mobile App</title><link>https://010101-sans.github.io/projects/ecommerce-app/</link><pubDate>Sat, 20 Jan 2024 10:00:00 +0000</pubDate><guid>https://010101-sans.github.io/projects/ecommerce-app/</guid><description>&lt;p&gt;A fully-featured e-commerce application built with Flutter and Firebase.&lt;/p&gt;
&lt;h2 id="features"&gt;Features&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;Product catalog with search and filters&lt;/li&gt;
&lt;li&gt;Secure user authentication&lt;/li&gt;
&lt;li&gt;Shopping cart and checkout&lt;/li&gt;
&lt;li&gt;Real-time order tracking&lt;/li&gt;
&lt;li&gt;Payment integration with Stripe&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="tech-stack"&gt;Tech Stack&lt;/h2&gt;
&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;Frontend&lt;/strong&gt;: Flutter&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Backend&lt;/strong&gt;: Firebase&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Database&lt;/strong&gt;: Firestore&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;Payments&lt;/strong&gt;: Stripe API&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="impact"&gt;Impact&lt;/h2&gt;
&lt;p&gt;The app handles 10,000+ active users with a 4.8-star rating on app stores.&lt;/p&gt;</description></item></channel></rss>